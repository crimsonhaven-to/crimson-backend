# Keep the build context small and avoid baking secrets / local state into the image.
.git
.github
.gitignore
.vscode
.claude
.env
*.env
!.env.example

# Leftover local SQLite files from before the PostgreSQL migration — never bake
# them into the image (state now lives in PostgreSQL, not in the build context).
*.db
*.db-journal
*.db-wal
*.db-shm

# Python caches / artifacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Dev/CI-only: the test suite, its tooling config and the throwaway local venv
# are never needed in the runtime image (the CI `gate` job runs them separately).
tests/
.venv-test/
requirements-dev.txt
pyproject.toml

# Docs / misc not needed at runtime
README.md
metadata_engine/README.md
New_System.md
New_System_Progress.md
