# Copy to `.env` on EACH database host and edit.
#
# Most values are IDENTICAL on all three hosts. The handful that MUST differ
# per host are marked  <-- PER HOST.  The example uses the LAN IPs 10.0.0.11/12/13
# for pg-1/pg-2/pg-3 — replace them with your real addresses everywhere.

# ============================================================================
# THIS HOST  (different on each of the three machines)
# ============================================================================
HOST_IP=10.0.0.11                 # <-- PER HOST: this machine's LAN IP
PATRONI_NAME=pg-1                 # <-- PER HOST: unique node name (pg-1 / pg-2 / pg-3)
ETCD_NAME=etcd-1                  # <-- PER HOST: unique etcd name (etcd-1 / etcd-2 / etcd-3)

# Leave as `new` for the very first bring-up of all three nodes. After the
# cluster is healthy you may change it to `existing` (optional, see README §11).
ETCD_INITIAL_CLUSTER_STATE=new

# ============================================================================
# THE CLUSTER  (identical on all three hosts)
# ============================================================================
PATRONI_SCOPE=crimson-cluster

# Every etcd member, as name=http://IP:2380 — list all three, same on every host.
ETCD_INITIAL_CLUSTER=etcd-1=http://10.0.0.11:2380,etcd-2=http://10.0.0.12:2380,etcd-3=http://10.0.0.13:2380

# Every etcd client endpoint, as IP:2379 — list all three, same on every host.
ETCD_CLIENT_HOSTS=10.0.0.11:2379,10.0.0.12:2379,10.0.0.13:2379

# Storage — point these at your RAID1 mount.
PGDATA_DIR=/srv/crimson-pgdata
PGBACKREST_REPO=/srv/crimson-pgbackrest

# ============================================================================
# SECRETS  (identical on all three hosts — generate once, paste on all three)
#   generate a strong value with:  openssl rand -hex 24
# ============================================================================
SUPERUSER_PASSWORD=CHANGE_ME_superuser_password
REPLICATION_PASSWORD=CHANGE_ME_replication_password
PATRONI_RESTAPI_USERNAME=admin
PATRONI_RESTAPI_PASSWORD=CHANGE_ME_restapi_password

# The application login the Crimsonhaven API uses (goes into DATABASE_URL).
CRIMSON_APP_USER=crimson
CRIMSON_APP_PASSWORD=CHANGE_ME_app_password
CRIMSON_APP_DB=crimson
