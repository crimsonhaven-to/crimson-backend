# --- Required ---------------------------------------------------------------
# TMDB Read Access Token (v4) or legacy API key — needed for metadata & search.
TMDB_API_KEY=YOUR_TMDB_API_KEY

# --- Stream proxy signing (IMPORTANT for production / multi-replica) ---------
# The PlayIMDb & AnimeSuge sources sign their same-origin proxy URLs with an
# HMAC so the proxy can't be abused as an open relay. The secret MUST be stable
# across restarts and identical on every replica, or proxied playback returns
# intermittent 403s. Generate one with:  openssl rand -hex 32
# If unset, a random per-process secret is used (OK for a single dev instance).
PROXY_SECRET=
# Per-source overrides (rarely needed; PROXY_SECRET covers both):
# PLAYIMDB_PROXY_SECRET=
# ANIMESUGE_PROXY_SECRET=

# --- Persistence ------------------------------------------------------------
# Where the SQLite DBs live. In Docker these point at the persisted volume so
# user data + the synced mapping survive redeploys. Defaults are repo-local.
# MAPPING_DB=anime_mappings.db
# ACCOUNTS_DB=accounts.db

# --- Scaling / scheduling ---------------------------------------------------
# The periodic Fribb mapping resync rebuilds the mapping tables wholesale, so it
# must run on exactly ONE replica. Set to false on every replica except one.
# RUN_DB_SYNC=true
# Seconds a sqlite call waits on a busy (locked) DB before erroring.
# SQLITE_BUSY_TIMEOUT=30

# --- CORS -------------------------------------------------------------------
# Comma-separated allowed origins. Defaults to the built-in dev + crimsonhaven
# list when unset. Lock this down in production.
# ALLOWED_ORIGINS=https://crimsonhaven.to,https://www.crimsonhaven.to

# --- Debugging --------------------------------------------------------------
# When set (to anything truthy), the global error handler includes exception
# detail in 500 responses. Leave UNSET in production.
# DEBUG=

# --- Optional: Jellyfin source ----------------------------------------------
# Stream from your own Jellyfin server (the "Jellyfin" source). Leave unset to
# disable. JELLYFIN_URL must be reachable from the backend container (LAN/Docker
# network is fine — it does not need to be public).
# JELLYFIN_URL=https://jellyfin.example.com
# JELLYFIN_USERNAME=your_jellyfin_user
# JELLYFIN_PASSWORD=your_jellyfin_password
