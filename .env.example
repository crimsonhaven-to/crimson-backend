# --- Required ---------------------------------------------------------------
# TMDB Read Access Token (v4) or legacy API key — needed for metadata & search.
TMDB_API_KEY=YOUR_TMDB_API_KEY

# --- Stream proxy signing (IMPORTANT for production / multi-replica) ---------
# HMAC secret shared with the external crimson-proxy. It signs the links minted by
# POST /sign (for client-resolved streams), the /subtitles_proxy links, and the
# server-side cache tickets, so none of those can be abused as an open relay. The
# secret MUST be stable across restarts and identical on every replica (and equal
# to each crimson-proxy's NITRO_PROXY_SECRET), or signed playback returns
# intermittent 403s. Generate one with:  openssl rand -hex 32
# If unset, a random per-process secret is used (OK for a single dev instance).
PROXY_SECRET=

# --- External CORS proxy (crimson-proxy) ------------------------------------
# Optional. The backend itself no longer resolves third-party sources — the client
# (crimson-sources) resolves them and asks POST /sign to mint a signed link to the
# external edge proxy, so segment bytes flow CDN -> edge -> viewer and never touch
# this backend. Set CRIMSON_PROXY_BASE to enable /sign (and the dashboard's proxy
# health view). Requires PROXY_SECRET above to be set AND equal to each proxy's
# NITRO_PROXY_SECRET. Comma-separate several hosts for free round-robin / failover
# (the signed link is valid on all of them). Leave blank to disable /sign (the
# client then falls back to the extension or stays direct).
# CRIMSON_PROXY_BASE=https://<site>.netlify.app,https://crimson-proxy.<acct>.workers.dev

# --- Database (PostgreSQL) --------------------------------------------------
# All state (TMDB<->AniList mapping + accounts/favorites/progress) lives in one
# PostgreSQL database, accessed through a pooled connection (see db_pool.py).
# Set DATABASE_URL to the full connection string (takes precedence):
# DATABASE_URL=postgresql://crimson:crimson@localhost:5432/crimson
# ...or provide the discrete parts (used only when DATABASE_URL is unset):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crimson
POSTGRES_USER=crimson
POSTGRES_PASSWORD=crimson
# Connection pool sizing and the startup wait for the DB to become reachable:
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=30
# Server-side prepared statements. Left unset they are DISABLED, which is required
# when the app runs behind a transaction-mode PgBouncer (deploy/pgbouncer) and is
# harmless otherwise. Only set this to an integer (e.g. 5) if you connect straight
# to Postgres with no pooler and want plan-caching back. See db_pool.py.
# DB_PREPARE_THRESHOLD=

# To scale the API tier past ~8 replicas without exhausting Postgres connections,
# put PgBouncer in front and point DATABASE_URL at port 6432 instead of 5432.
# Setup: deploy/pgbouncer/README.md.

# --- Scaling / scheduling ---------------------------------------------------
# The periodic Fribb mapping resync rebuilds the mapping tables wholesale, so it
# must run on exactly ONE replica. Set to false on every replica except one.
# RUN_DB_SYNC=true

# --- Non-anime metadata maintenance (tmdb_shows / tmdb_movies) --------------
# These tables are filled lazily (on open + from search/trending). The settings
# below keep them fresh and, optionally, pre-seed them. ALL of this heavy work is
# pinned to the single RUN_DB_SYNC replica (api-sync), so leave these at defaults
# on the serving replicas — they're only read there.
#
# Nightly slice refresh: there's no upstream to signal a TMDB change, so every
# night at METADATA_REFRESH_HOUR (local time) the oldest 1/METADATA_REFRESH_BUCKETS
# of each table is re-pulled from TMDB. Over a full cycle (default 14 nights) every
# row is refreshed, then it repeats. Defaults shown.
# METADATA_REFRESH_BUCKETS=14
# METADATA_REFRESH_HOUR=4
#
# Catalogue backfill: page TMDB discover to pre-populate the tables beyond what's
# been browsed. Trigger it anytime from the Admin dashboard (the request is queued
# in the DB and drained by api-sync) — or run it once at startup with the flag
# below. Paced between pages to stay rate-limit + WAL friendly. Each page is ~20
# rows; ~1.5 KB/row, so even 500 pages per kind is well under a GB.
# RUN_METADATA_BACKFILL=false
# METADATA_BACKFILL_PAGES=100

# --- CORS -------------------------------------------------------------------
# Comma-separated allowed origins. Defaults to the built-in dev + crimsonhaven
# list when unset. Lock this down in production.
# ALLOWED_ORIGINS=https://crimsonhaven.to,https://www.crimsonhaven.to

# --- Login wall (email+password auth) ---------------------------------------
# When true (default), every content endpoint (search/trending/info/seasons/
# watch/overview/catalogue/supporters/account...) requires a valid session
# bearer token. Auth endpoints, /health, the signed stream proxies/player, and
# the Ko-fi webhook stay public. Set false to reopen the whole API.
# REQUIRE_LOGIN=true
#
# Invite code(s) required to register a new account — BOTH email+password and
# Ed25519 mnemonic signup are gated by this (comma-separated for multiple). If
# EMPTY/unset, registration is closed and nobody new can sign up — which fails
# safe for a private site. A user with a valid code may choose either account
# type; existing mnemonic accounts log in without a code. Single-use Discord-bot
# tokens work too. Generate one with: openssl rand -hex 12
SIGNUP_INVITE_CODE=
#
# Frontend origin used to build the verification + password-reset links emailed
# to users. Defaults to https://crimsonhaven.to.
# FRONTEND_BASE_URL=https://crimsonhaven.to
#
# Admin dashboard seed (comma-separated emails). Any EXISTING account whose email
# is listed here is promoted to admin on startup, so you can reach /admin without
# editing the DB. Register/verify the account first, then list its email here.
# Afterwards you can promote/demote other admins from the dashboard itself.
ADMIN_EMAILS=

# --- Discord invite bot (single-use invite tokens) --------------------------
# Optional. Runs as its own process/container (python -m discord_bot) and lets
# ONE whitelisted Discord user mint single-use invite tokens for signup — an
# alternative to the shared, reusable SIGNUP_INVITE_CODE above. DM the bot
# "!invite" and paste the returned code into the signup form's invite field.
# Leave DISCORD_BOT_TOKEN empty to keep the bot disabled.
#   * Create the bot at https://discord.com/developers/applications -> Bot, copy
#     its token, and enable "Message Content Intent" under Privileged Gateway
#     Intents (needed to read commands in servers; DMs work without it).
#   * DISCORD_OWNER_ID is YOUR numeric Discord user id (enable Developer Mode,
#     right-click your name -> Copy User ID). Only this user may use the bot.
# Run exactly ONE instance — a second login with the same token fights the first.
DISCORD_BOT_TOKEN=
DISCORD_OWNER_ID=
# Command prefix for the bot's chat commands. Default "!".
# DISCORD_COMMAND_PREFIX=!

# --- SMTP (transactional email: verification + password reset) --------------
# Unset SMTP_HOST disables email entirely (registration still works, but no
# verification/reset mail is sent — users would be stuck unverified). Infomaniak
# example shown; SMTP_SECURITY is starttls (default) | ssl | none.
# SMTP_HOST=mail.infomaniak.com
# SMTP_PORT=587
# SMTP_SECURITY=starttls
# SMTP_USER=service@example.com
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=service@example.com
# SMTP_FROM_NAME=CrimsonHaven

# --- Debugging --------------------------------------------------------------
# When set (to anything truthy), the global error handler includes exception
# detail in 500 responses. Leave UNSET in production.
# DEBUG=

# --- Deployment / ops (rarely changed) --------------------------------------
# Trusted proxy IPs uvicorn honours X-Forwarded-* from. Behind the Swarm ingress
# / a reverse proxy this usually needs to be "*" so client IPs (rate limiting,
# logs) are correct. See the Dockerfile/compose for how it's wired.
# FORWARDED_ALLOW_IPS=
# slowapi rate-limit storage backend. Defaults to in-memory (per-replica); point
# at redis://… to share limits across replicas.
# RATE_LIMIT_STORAGE_URI=
# Source-health probe canary (the title the Admin "Source Health" view tests).
# Defaults to Attack on Titan S1E1.
# HEALTH_CANARY_TITLE=
# HEALTH_CANARY_TMDB=1429
# HEALTH_CANARY_SEASON=1
# HEALTH_CANARY_EPISODE=1

# --- Optional: Ko-fi supporters ("Lumi's Loved Mortals") --------------------
# Powers POST /kofi/webhook + the public GET /supporters list. Ko-fi has no
# supporters API — it only POSTs a webhook on each payment — so this token is the
# shared secret that authenticates those webhooks. Find it (and set the webhook
# URL to https://<your-backend>/kofi/webhook) under Ko-fi → Settings → Advanced →
# Webhooks / API. If KOFI_VERIFICATION_TOKEN is unset, POST /kofi/webhook returns
# 503 (fails closed) and no supporters are ever recorded.
KOFI_VERIFICATION_TOKEN=
# A subscriber is listed only while their last payment is within this many days
# (one billing cycle + grace); Ko-fi sends no cancellation event, so this is how
# the list "shrinks". One-time tippers are always kept. Default 35.
# KOFI_ACTIVE_WINDOW_DAYS=35
# Per-replica in-memory cache TTL (seconds) for the public list. Default 60.
# KOFI_LIST_CACHE_TTL=60

# --- Optional: Changelog (public /changelog from GitHub Releases) -----------
# Deploys are cut as published GitHub Releases, so your release notes ARE the
# changelog. GET /changelog serves a cached, newest-first view of them. A PRIVATE
# repo works fine — the REST API returns releases when given a read token:
#   * Fine-grained PAT (recommended): repo = crimson-backend, Permissions ->
#     Repository -> Contents: Read-only. Create at
#     https://github.com/settings/tokens?type=beta
#   * ...or a classic token with the `repo` scope.
# Unset => /changelog returns 503 (feature disabled). The token is read-only.
GITHUB_TOKEN=
# owner/repo to read releases from. Defaults to crimsonhaven-to/crimson-backend.
# GITHUB_REPO=crimsonhaven-to/crimson-backend
# Per-replica cache TTL in seconds between GitHub refreshes (default 1800 = 30m).
# Conditional ETag requests make refreshes near-free, so this can stay low.
# CHANGELOG_CACHE_TTL=1800
# How many releases to surface (default 30, max 100), and whether to include
# pre-releases (default true; drafts are always hidden).
# CHANGELOG_MAX_ENTRIES=30
# CHANGELOG_INCLUDE_PRERELEASES=true

# --- Optional: OpenSubtitles (external player subtitles) ---------------------
# Adds OpenSubtitles-sourced subtitle tracks to the in-app player (GET /subtitles,
# merged into CrimsonPlayer's CC menu). Unset => /subtitles returns 503 (feature
# disabled). The key stays server-side; the browser only ever sees a signed,
# same-origin /subtitles_proxy URL (the proxy is the only step that spends your
# OpenSubtitles DOWNLOAD quota — searches are free — and converted results are
# cached by file id so an episode never costs quota twice).
#   * Register a consumer/app at https://www.opensubtitles.com/en/consumers to get
#     an API key. The free tier has a small daily download quota.
OPENSUBTITLES_API_KEY=
# The OpenSubtitles API requires a descriptive User-Agent identifying your app
# (defaults to "CrimsonHaven v1.0"). Set to whatever you registered, if different.
# OPENSUBTITLES_APP_NAME=CrimsonHaven v1.0
# Seconds to cache a subtitle SEARCH result per (title, langs) (default 3600).
# SUBTITLES_SEARCH_TTL=3600
# Signing for /subtitles_proxy reuses PROXY_SECRET above; override only if needed:
# SUBTITLES_PROXY_SECRET=

# --- Optional: Jellyfin source ----------------------------------------------
# Stream from your own Jellyfin server (the "Jellyfin" source). Leave unset to
# disable. JELLYFIN_URL must be reachable from the backend container (LAN/Docker
# network is fine — it does not need to be public).
JELLYFIN_URL=https://jellyfin.example.com
JELLYFIN_USERNAME=your_jellyfin_user
JELLYFIN_PASSWORD=your_jellyfin_password
# When true, the access token is injected at the crimson-proxy EDGE instead of by
# this backend (the source then runs E2/edge-only). Default false (backend injects).
# JELLYFIN_EDGE_INJECT=false

# --- Optional: Server-side video cache --------------------------------------
# When enabled in the Admin Dashboard, playing an episode downloads the COMPLETE
# stream (remuxed to mp4 with ffmpeg) to a NAS target you register there, and
# replays it from disk as a named source. The master switch + NAS targets live in
# the DB (managed from the dashboard) — these env vars only tune the downloader
# and rarely need changing. ffmpeg must be on PATH (it's in the Docker image).
#
# The background ffmpeg download loop runs only on the replica with this set true.
# Defaults true (so a single-container deploy still caches); the Swarm stack sets
# it false on api/api-sync and true only on the dedicated cache-worker service.
# RUN_CACHE_WORKER=true
# Base URL the downloader uses to reach the backend's own stream proxies. Loopback
# by default so cache traffic never leaves the host; only change if uvicorn binds
# elsewhere.
# CACHE_INTERNAL_BASE=http://127.0.0.1:8000
# How many episodes to download at once (keep low to be gentle on bandwidth/NAS).
# CACHE_MAX_CONCURRENT=1
# Per-episode download timeout, seconds.
# CACHE_DOWNLOAD_TIMEOUT=3600
# Skip a download unless the target has at least this much free space (bytes).
# CACHE_MIN_FREE_BYTES=2147483648
# Max episodes queued for download before new ones are dropped.
# CACHE_QUEUE_MAX=200
