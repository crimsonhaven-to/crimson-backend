TMDB_API_KEY=YOUR_TMDB_API_KEY

# Optional: stream from your own Jellyfin server (the "Jellyfin" source).
# Leave unset to disable. JELLYFIN_URL must be reachable from the backend
# container (LAN/Docker network is fine — it does not need to be public).
JELLYFIN_URL=https://jellyfin.example.com
JELLYFIN_USERNAME=your_jellyfin_user
JELLYFIN_PASSWORD=your_jellyfin_password
